# The ID of your GitHub App
APP_ID=
WEBHOOK_SECRET=development

# Use `trace` to get verbose logging or `info` to show less
LOG_LEVEL=debug

# Go to https://smee.io/new set this to the URL that you are redirected to.
WEBHOOK_PROXY_URL=

# OpenAI Responses API
OPENAI_API_KEY=
OPENAI_MODEL=gpt-5.5

# Optional outbound HTTP proxy for GitHub API and OpenAI API requests.
# CODECAT_PROXY_URL applies to both HTTP and HTTPS; use the split variables
# below when the two protocols need different proxies.
CODECAT_PROXY_URL=
CODECAT_HTTP_PROXY=
CODECAT_HTTPS_PROXY=
CODECAT_NO_PROXY=

# Code Cat behavior
CODECAT_TIMEZONE=Asia/Shanghai
CODECAT_DAILY_CRON=0 3 * * *
CODECAT_REVIEW_MODE=incremental
CODECAT_AUTO_FIX_ENABLED=true
CODECAT_VERIFY_MODE=lightweight
CODECAT_VERIFY_COMMANDS=npm test -- --run,npm run build
CODECAT_EXCLUDE_GLOBS=.env*,**/*.pem,node_modules/**,lib/**,dist/**
CODECAT_MAX_FILES=30
CODECAT_MAX_BYTES=120000
CODECAT_MAX_FIX_FILES=5
CODECAT_MAX_FIX_BYTES=80000
CODECAT_DISABLE_SCHEDULER=false
