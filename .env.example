# GitHub App 基础配置
APP_ID=
PRIVATE_KEY=
WEBHOOK_SECRET=development
GITHUB_CLIENT_ID=
GITHUB_CLIENT_SECRET=

# 日志级别：trace 输出最详细，info 更安静
LOG_LEVEL=debug

# Webhook 代理地址：本地开发可访问 https://smee.io/new 创建
WEBHOOK_PROXY_URL=

# OpenAI Responses API 配置
OPENAI_API_KEY=
OPENAI_MODEL=gpt-5.5
OPENAI_BASE_URL=https://api.openai.com/v1

# 可选：GitHub API 与 OpenAI API 出站代理
# CODECAT_PROXY_URL 同时应用到 HTTP 与 HTTPS；如需区分协议，请使用下面两个变量。
CODECAT_PROXY_URL=
CODECAT_HTTP_PROXY=
CODECAT_HTTPS_PROXY=
CODECAT_NO_PROXY=

# Code Cat 行为配置
CODECAT_TIMEZONE=Asia/Shanghai
CODECAT_DAILY_CRON=0 3 * * *
CODECAT_REVIEW_MODE=incremental
CODECAT_AUTO_FIX_ENABLED=true
CODECAT_VERIFY_MODE=lightweight
CODECAT_VERIFY_COMMANDS=npm test -- --run,npm run build
CODECAT_EXCLUDE_GLOBS=.env*,**/*.pem,node_modules/**,lib/**,dist/**
CODECAT_MAX_FILES=30
CODECAT_MAX_BYTES=120000
CODECAT_MAX_FIX_FILES=5
CODECAT_MAX_FIX_BYTES=80000
CODECAT_DISABLE_SCHEDULER=false
